# Validator node settings loaded by ./start_validator.sh
PYTHON_BIN=
NETUID=476
WALLET_NAME=my_wallet
WALLET_HOTKEY=validator_hotkey
SUBTENSOR_NETWORK=test
SUBTENSOR_CHAIN_ENDPOINT=
AXON_PORT=8092
MOCK=0
AXON_OFF=0
TIMEOUT=10
SAMPLE_SIZE=50
NUM_CONCURRENT_FORWARDS=1
CHALLENGE_INTERVAL=12
EPOCH_LENGTH=100
DISABLE_SET_WEIGHTS=0
VPERMIT_TAO_LIMIT=4096

# Benchmark and sandbox settings.
SLUICE_TASK_API=
SLUICE_SKIP_SANDBOX_BUILD=0
SLUICE_SANDBOX_IMAGE=sluice-router-agent:latest
# Set to 1 when Docker is only reachable through `flatpak-spawn --host docker`.
SLUICE_USE_HOST_DOCKER_CLI=0
SLUICE_ARTIFACT_CACHE_DIR=
SLUICE_HOST_RUNTIME_ROOT=
MAX_CONCURRENT_SANDBOXES=4
SANDBOX_TIMEOUT=45
SLUICE_LOCAL_DEV_EXECUTION=0

# Optional Hugging Face auth for validators.
# Public miner artifacts do not need a token. Private/gated Hugging Face repos do.
HF_TOKEN=
HF_ENDPOINT=

# Local smoke-test only; leave empty for real validator operation.
SLUICE_MOCK_ROUTER_MANIFEST_PATH=

# Optional future serving-layer secret. Not used by validator benchmarking.
GEMINI_API_KEY=
