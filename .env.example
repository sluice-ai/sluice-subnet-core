# Miner settings
# Use a public git URL or a file:// URL for local validator testing.
ROUTER_REPO_URL=https://github.com/your-org/your-sluice-router.git
ROUTER_LABEL=baseline-router
ROUTER_VERSION=0.1.0
ROUTER_SUMMARY=Cost-first feasible routing policy for Sluice benchmark tasks.
ROUTER_SUPPORTED_CAPABILITIES=json-mode,function-calling,streaming,codegen
ROUTER_SUPPORTED_PRIVACY_TIERS=public,internal,confidential

# Validator settings
# Leave blank to use the bundled local benchmark set.
SLUICE_TASK_API=
SLUICE_BENCHMARK_SEED=7
SANDBOX_TIMEOUT=45
MAX_CONCURRENT_SANDBOXES=4
SLUICE_SKIP_SANDBOX_BUILD=0
