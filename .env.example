# Miner artifact announcement
# For testnet/mainnet, the manifest's artifact_uri must be public http(s), not file://.
ROUTER_MANIFEST_PATH=
ROUTER_ARTIFACT_URI=
ROUTER_ARTIFACT_SHA256=
ROUTER_ARTIFACT_FORMAT=tar.gz
ROUTER_ENTRYPOINT_PATH=agent.py
ROUTER_ENTRYPOINT_CALLABLE=agent_main
ROUTER_LABEL=sluice-router
ROUTER_VERSION=0.1.0
ROUTER_SUMMARY=
ROUTER_SUPPORTED_CAPABILITIES=json-mode
ROUTER_SUPPORTED_PRIVACY_TIERS=public

# Validator settings
SLUICE_TASK_API=
SLUICE_SKIP_SANDBOX_BUILD=0
SLUICE_SANDBOX_IMAGE=sluice-router-agent:latest
SLUICE_ARTIFACT_CACHE_DIR=
MAX_CONCURRENT_SANDBOXES=4
SANDBOX_TIMEOUT=45
# Keep this 0 on testnet/mainnet. 1 is only for local smoke tests.
SLUICE_LOCAL_DEV_EXECUTION=0
SLUICE_MOCK_ROUTER_MANIFEST_PATH=

# Optional future serving-layer secret. Not used by validator benchmarking.
GEMINI_API_KEY=
