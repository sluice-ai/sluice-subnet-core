# Miner node settings loaded by ./start_miner.sh
PYTHON_BIN=
NETUID=476
WALLET_NAME=my_wallet
WALLET_HOTKEY=miner_live
SUBTENSOR_NETWORK=test
SUBTENSOR_CHAIN_ENDPOINT=
AXON_PORT=8093
MOCK=0
EPOCH_LENGTH=100
FORCE_VALIDATOR_PERMIT=1
ALLOW_NON_REGISTERED=0

# Router artifact announcement.
# For testnet/mainnet, publish the tarball to Hugging Face and point this at
# the local manifest rewritten by `python -m sluice.router.builder --hf-repo-id ...`.
ROUTER_MANIFEST_PATH=
ROUTER_ARTIFACT_URI=
ROUTER_ARTIFACT_SHA256=
ROUTER_ARTIFACT_FORMAT=tar.gz
ROUTER_ENTRYPOINT_PATH=agent.py
ROUTER_ENTRYPOINT_CALLABLE=agent_main
ROUTER_LABEL=sluice-router
ROUTER_VERSION=0.1.0
ROUTER_SUMMARY=
ROUTER_SUPPORTED_CAPABILITIES=json-mode
ROUTER_SUPPORTED_PRIVACY_TIERS=public

# Keep this 0 for testnet/mainnet. Set to 1 only for local single-machine tests.
SLUICE_ALLOW_LOCAL_ARTIFACT=0

# Hugging Face publish target for `python -m sluice.router.builder`.
HF_TOKEN=
HF_ENDPOINT=
HF_ROUTER_REPO_ID=
HF_ROUTER_REPO_TYPE=model
HF_ROUTER_PATH_PREFIX=routers
HF_ROUTER_REVISION=main
HF_ROUTER_PRIVATE=0
